{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "packages/**/*.ts", "services/**/*.ts"],
  "exclude": [
    "dist",
    "node_modules",
    ".runtime",
    "release",
    "tools",
    "packages/**/*.test.ts",
    "packages/**/*.spec.ts",
    "packages/**/__tests__/**/*.ts",
    "packages/**/dist-smoke/**/*.ts",
    "services/**/*.test.ts",
    "services/**/*.spec.ts",
    "services/**/__tests__/**/*.ts"
  ]
}
