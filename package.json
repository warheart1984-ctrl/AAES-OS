{
  "name": "@aaes-os/aaes-os-workspace",
  "version": "0.2.0",
  "private": true,
  "description": "AAES-OS monorepo — UCR runtime spine packages (TypeScript)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run build && pnpm exec vitest run",
    "lint": "pnpm exec eslint \"packages/**/*.{js,jsx,ts,tsx,mjs,cjs}\" \"services/**/*.{js,jsx,ts,tsx,mjs,cjs}\" --max-warnings 0",
    "test:packages": "pnpm -r run test",
    "release:build": "node release/build-release.ts",
    "release:package": "node release/package-release.ts",
    "release:sign": "node release/sign-release.ts",
    "release:verify": "node release/verify-release.ts",
    "integrations:evidence": "tsx tools/external-integration-evidence.ts",
    "hardening:evidence": "tsx tools/production-hardening-evidence.ts",
    "release": "pnpm build && pnpm run release:build && pnpm run release:package && pnpm run release:sign && pnpm run release:verify",
    "cori:push": "tsx release/post-push.ts",
    "cori:tag": "tsx release/post-tag.ts",
    "cori:validate": "tsx release/constitutional-validator.ts",
    "dropbox:sync": "tsx release/repo-dropbox-sync.ts",
    "dropbox:install-hook": "tsx scripts/install-dropbox-sync-hook.ts",
    "dropbox:watch": "tsx scripts/watch-dropbox-sync.ts",
    "dropbox:install-service": "tsx scripts/install-dropbox-service.ts",
    "dropbox:uninstall-service": "tsx scripts/install-dropbox-service.ts --Uninstall",
    "release:drift": "pnpm exec vitest run packages/aaes-governance/src/proofSurface.test.ts tests/release/artifact-governance.test.ts tests/release/cis-standards-importer.test.ts tests/release/external-standards.test.ts tests/release/pricing-model.test.ts tests/release/codex-handoff-orchestrator-summary.test.ts tests/release/cis-conformance-generation.test.ts",
    "release:conformance-artifact": "tsx tools/cis-conformance-artifact.ts",
    "build:legacy": "tsc -p tsconfig.json",
    "test:legacy": "npm run build:legacy && node --test dist/tests/*.test.js",
    "drift-demo": "tsx tools/scripts/drift-demo.ts",
    "patch-demo": "tsx tools/patch-effectiveness-demo.ts",
    "telemetry": "tsx tools/telemetry-cli.ts",
    "coverage:docs": "tsx tools/check-doc-coverage.ts",
    "codex-handoff": "tsx tools/codex-handoff-cli.ts",
    "codex-handoff-prompt": "tsx tools/codex-handoff-prompt.ts",
    "codex-handoff-ingest": "tsx tools/codex-handoff-ingest.ts",
    "codex-handoff-orchestrate": "tsx tools/codex-handoff-orchestrator.ts",
    "codex-handoff-smoke": "tsx tools/codex-handoff-smoke.ts",
    "ops-console": "pnpm --filter @aaes-os/ops-console start",
    "platform-api": "pnpm --filter @aaes-os/platform-api start",
    "platform-web": "pnpm --filter @aaes-os/platform-web dev",
    "organism": "pnpm --filter @aaes-os/platform-cli exec organism",
    "mesh:simulate": "pnpm --filter @aaes-os/mesh-simulator run simulate",
    "free-coding": "tsx tools/free-coding-cli.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aaes-os/architect-agent": "workspace:*",
    "@aaes-os/coding-assistant": "workspace:*"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "0.28.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.21",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.15.0",
  "pnpm": {
    "overrides": {
      "undici": "6.27.0",
      "postcss": "8.5.10",
      "uuid": "11.1.1",
      "zod@3.25.76": "https://npm.aikido.io/2faf376294ec770485c7c39/zod@3.25.76-aikido.1"
    }
  }
}
