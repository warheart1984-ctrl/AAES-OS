# Platform URLs
PLATFORM_API_URL=http://localhost:4100
PLATFORM_WEB_URL=http://localhost:3000

# Google Drive OAuth (do not commit real values)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/integrations/google-drive/callback
GOOGLE_DRIVE_SCOPES=openid email profile https://www.googleapis.com/auth/drive.file
GOOGLE_DRIVE_STATE_SECRET=generate-a-long-random-value
GOOGLE_DRIVE_TOKEN_KEY=generate-a-separate-long-random-value
GOOGLE_DRIVE_TOKEN_VAULT=.local/google-drive/tokens.json
GOOGLE_DRIVE_EVIDENCE_LOG=.local/google-drive/evidence.jsonl
