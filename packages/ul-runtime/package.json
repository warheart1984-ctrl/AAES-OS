{
  "name": "@aaes-os/ul-runtime",
  "version": "0.1.0",
  "description": "Live Universal Language verb runtime surface for compiling UL actions into ISL-compatible intent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
